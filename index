<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shambhavi — Career Map</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Caveat:wght@400;600;700&family=Caveat+Brush&display=swap');

  * { margin:0; padding:0; box-sizing:border-box; }

  :root {
    --paper: #f0ece0;
    --ink: #1c1410;
    --ink-light: #5a4a3a;
    --terra: #c0392b;
    --blue: #2c4a6e;
    --gold: #9a7020;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--paper);
    font-family: 'Caveat', cursive;
    overflow-x: hidden;
    cursor: crosshair;
  }

  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image: url('data:image/jpeg;base64,');
    background-size: cover;
    background-position: center;
    pointer-events: none;
    z-index: 0;
  }

  .stage {
    position: relative; z-index: 1;
    display: flex; flex-direction: column; align-items: center;
  }

  /* ===== INTRO ===== */
  .intro {
    height: 100vh; width: 100%;
    display: flex; flex-direction: column;
    align-items: flex-start; justify-content: center;
    padding: 0 7vw;
    position: relative;
  }

  .intro-eyebrow {
    font-family: 'Libre Baskerville', serif;
    font-style: italic; font-size: clamp(14px,1.8vw,18px);
    color: var(--ink-light); letter-spacing: .12em;
    opacity: 0; animation: fadeUp .8s ease forwards .2s;
    margin-bottom: 12px;
  }

  .intro-name {
    font-family: 'Caveat Brush', cursive;
    font-size: clamp(72px,13vw,148px);
    color: var(--ink); line-height: .92;
    opacity: 0; transform: translateY(24px);
    animation: fadeUp .9s ease forwards .5s;
    position: relative; display: inline-block;
  }

  .intro-name::after {
    content: '';
    position: absolute; bottom: -10px; left: 0; right: 0; height: 6px;
    background: var(--terra);
    transform: scaleX(0); transform-origin: left;
    animation: scaleIn .8s ease forwards 1.4s;
  }

  .intro-sub {
    font-family: 'Libre Baskerville', serif;
    font-size: clamp(15px,2vw,21px); color: var(--ink-light);
    max-width: 540px; line-height: 1.7; margin-top: 28px;
    opacity: 0; animation: fadeUp .8s ease forwards 1s;
  }

  /* Right-side decorative doodle on intro */
  .intro-doodle {
    position: absolute; right: 6vw; top: 50%;
    transform: translateY(-50%);
    opacity: 0; animation: fadeUp 1s ease forwards 1.6s;
  }

  .scroll-hint {
    position: absolute; bottom: 40px; left: 50%;
    transform: translateX(-50%);
    font-size: 16px; color: var(--ink-light);
    opacity: 0; animation: fadeUp .8s ease forwards 1.9s, bobble 2.4s ease-in-out infinite 2.7s;
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    white-space: nowrap;
  }

  /* ===== MAP SECTIONS ===== */
  .map-section {
    width: 100%;
    padding: 60px 3vw 100px;
  }

  .map-svg { width: 100%; overflow: visible; }

  /* Node ellipse — dasharray set by JS */
  .node-circle {
    fill: none; stroke: var(--ink); stroke-width: 3;
    stroke-linecap: round;
    transition: stroke-dashoffset 1.8s cubic-bezier(.25,0,.2,1);
  }

  .branch-line {
    fill: none; stroke: var(--ink); stroke-width: 2.2;
    stroke-linecap: round;
    stroke-dasharray: 600; stroke-dashoffset: 600;
    transition: stroke-dashoffset 1s cubic-bezier(.4,0,.2,1);
  }
  .branch-line.drawn { stroke-dashoffset: 0; }

  .scratch-line {
    fill: none; stroke: var(--terra); stroke-width: 3.5;
    stroke-linecap: round;
    stroke-dasharray: 300; stroke-dashoffset: 300;
    transition: stroke-dashoffset .45s ease;
  }
  .scratch-line.drawn { stroke-dashoffset: 0; }

  .map-text {
    font-family: 'Caveat', cursive;
    fill: var(--ink); opacity: 0;
    transition: opacity .5s ease;
  }
  .map-text.shown { opacity: 1; }

  .icon-group { opacity: 0; transition: opacity .6s ease; }
  .icon-group.shown { opacity: 1; }

  /* ===== FORMULA SECTION ===== */
  .formula-section {
    width: 100%;
    padding: 60px 3vw 100px;
    opacity: 0; transform: translateY(24px);
    transition: opacity .9s ease, transform .9s ease;
  }
  .formula-section.shown { opacity: 1; transform: none; }

  .formula-svg { width: 100%; overflow: visible; }

  .formula-line {
    fill: none; stroke: var(--ink); stroke-width: 2.2;
    stroke-linecap: round;
    stroke-dasharray: 700; stroke-dashoffset: 700;
    transition: stroke-dashoffset 1s cubic-bezier(.4,0,.2,1);
  }
  .formula-line.drawn { stroke-dashoffset: 0; }

  .formula-text {
    font-family: 'Caveat', cursive;
    fill: var(--ink); opacity: 0;
    transition: opacity .5s ease;
  }
  .formula-text.shown { opacity: 1; }

  /* ===== FINAL ===== */
  .final-panel {
    height: 100vh; width: 100%;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 28px; padding: 40px; text-align: center;
    position: relative;
  }

  .final-title {
    font-family: 'Caveat Brush', cursive;
    font-size: clamp(54px,10vw,122px);
    color: var(--ink); line-height: 1;
    opacity: 0; transform: translateY(30px);
    transition: opacity 1s ease, transform 1s ease;
    position: relative;
  }
  .final-title.shown { opacity: 1; transform: none; }
  .final-title::after {
    content: '';
    position: absolute; bottom: -10px; left: 0; right: 0; height: 5px;
    background: var(--terra);
    transform: scaleX(0); transform-origin: left;
    transition: transform 1.2s ease 1s;
  }
  .final-title.shown::after { transform: scaleX(1); }

  .final-cta {
    font-family: 'Libre Baskerville', serif;
    font-style: italic; font-size: clamp(17px,2.4vw,28px);
    color: var(--ink-light); max-width: 600px; line-height: 1.6;
    opacity: 0; transition: opacity .9s ease .5s;
  }
  .final-cta.shown { opacity: 1; }

  /* ===== PROGRESS ===== */
  .progress-track {
    position: fixed; right: 18px; top: 50%;
    transform: translateY(-50%);
    display: flex; flex-direction: column; gap: 12px;
    z-index: 100;
  }
  .progress-dot {
    width: 9px; height: 9px; border-radius: 50%;
    border: 2px solid var(--ink); background: transparent;
    transition: background .3s, transform .3s;
  }
  .progress-dot.active {
    background: var(--terra); border-color: var(--terra);
    transform: scale(1.4);
  }

  @keyframes fadeUp { to { opacity:1; transform:translateY(0); } }
  @keyframes scaleIn { to { transform:scaleX(1); } }
  @keyframes bobble {
    0%,100% { transform: translateX(-50%) translateY(0); }
    50%      { transform: translateX(-50%) translateY(9px); }
  }

  .ink-drop {
    position: fixed; border-radius: 50%; background: var(--terra);
    pointer-events: none; z-index: 9999;
    animation: inkFade .7s ease forwards;
  }
  @keyframes inkFade {
    0%   { transform: scale(1); opacity: .6; }
    100% { transform: scale(0); opacity: 0; }
  }
</style>
</head>
