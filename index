  </div>

  <!-- SECTION 3: THE FORMULA -->
  <div class="formula-section" data-section="3" id="formulaSection">
    <svg class="formula-svg" viewBox="0 0 1200 500" id="svg3">

      <!-- Chapter label -->
      <text class="formula-text" style="font-family:'Caveat Brush',cursive; font-size:22px; fill:#8a7a6a;" x="40" y="40" id="f-ch">chapter 3: what working with me looks like →</text>

      <!-- THE FORMULA — big and drawn -->
      <!-- Left term -->
      <text class="formula-text" style="font-size:48px; font-weight:700;" x="40" y="116" id="f-t1">creative vision</text>
      <!-- Plus sign -->
      <text class="formula-text" style="font-size:52px; fill:var(--terra);" x="510" y="116" id="f-plus">+</text>
      <!-- Right term -->
      <text class="formula-text" style="font-size:48px; font-weight:700; fill:var(--blue);" x="572" y="116" id="f-t2">AI leverage</text>

      <!-- Equals line drawn across -->
      <line class="formula-line" x1="40" y1="138" x2="1160" y2="138" id="f-eq"/>

      <!-- Result — the BIG claim, but framed as an offer not a brag -->
      <text class="formula-text" style="font-family:'Caveat Brush',cursive; font-size:58px; fill:var(--ink);" x="40" y="202" id="f-res">faster work that actually means something</text>

      <!-- Thin rule -->
      <line class="formula-line" x1="40" y1="224" x2="1160" y2="224" id="f-div" style="stroke:#c8c0b0; stroke-width:1;"/>

      <!-- Three proof boxes — sketchy hand-drawn borders -->
      <!-- Box 1 -->
      <g class="icon-group" id="box1">
        <path d="M40,242 Q42,240 260,240 Q262,242 262,320 Q260,322 40,322 Q38,320 38,242 Z" fill="none" stroke="var(--terra)" stroke-width="1.8" stroke-dasharray="5,4"/>
        <text class="formula-text" style="font-size:14px; fill:var(--terra);" x="54" y="264" id="f-b1a">instead of</text>
        <text class="formula-text" style="font-size:20px; font-weight:700;" x="54" y="289" id="f-b1b">weeks of research</text>
        <text class="formula-text" style="font-size:15px; fill:var(--blue);" x="54" y="313" id="f-b1c">→ hours of synthesis</text>
      </g>

      <!-- Box 2 -->
      <g class="icon-group" id="box2">
        <path d="M460,242 Q462,240 740,240 Q742,242 742,320 Q740,322 460,322 Q458,320 458,242 Z" fill="none" stroke="var(--terra)" stroke-width="1.8" stroke-dasharray="5,4"/>
        <text class="formula-text" style="font-size:14px; fill:var(--terra);" x="474" y="264" id="f-b2a">instead of</text>
        <text class="formula-text" style="font-size:20px; font-weight:700;" x="474" y="289" id="f-b2b">a team of specialists</text>
        <text class="formula-text" style="font-size:15px; fill:var(--blue);" x="474" y="313" id="f-b2c">→ one compound operator</text>
      </g>

      <!-- Box 3 -->
      <g class="icon-group" id="box3">
        <path d="M880,242 Q882,240 1160,240 Q1162,242 1162,320 Q1160,322 880,322 Q878,320 878,242 Z" fill="none" stroke="var(--terra)" stroke-width="1.8" stroke-dasharray="5,4"/>
        <text class="formula-text" style="font-size:14px; fill:var(--terra);" x="894" y="264" id="f-b3a">instead of</text>
        <text class="formula-text" style="font-size:20px; font-weight:700;" x="894" y="289" id="f-b3b">iterating indefinitely</text>
        <text class="formula-text" style="font-size:15px; fill:var(--blue);" x="894" y="313" id="f-b3c">→ ship with conviction</text>
      </g>

      <!-- Source annotation — small, honest, handwritten -->
      <text class="formula-text" style="font-size:14px; fill:#8a7a6a; font-style:italic;" x="40" y="366" id="f-src">↑ grounded in a Google ML director's insight: hire people who use AI to do better work faster —</text>
      <text class="formula-text" style="font-size:14px; fill:#8a7a6a; font-style:italic;" x="40" y="386" id="f-src2">not people who use company time and resources to keep up.</text>

      <!-- Down arrow to portfolio — eager CTA -->
      <text class="formula-text" style="font-family:'Caveat Brush',cursive; font-size:26px; fill:var(--terra);" x="600" y="452" text-anchor="middle" id="f-cta">the work is below ↓ take a look</text>
    </svg>
  </div>

  <!-- FINAL PANEL -->
  <div class="final-panel" data-section="4">
    <div class="final-title" id="finalTitle">ready when you are.</div>
    <div class="final-cta" id="finalCta">
      I see a certain life for myself — and I won't stop until I get it. Let me show you what that looks like in practice.
    </div>
  </div>

</div>

<script>
  // ---- PROGRESS ----
  const sections = document.querySelectorAll('[data-section]');
  const track = document.getElementById('progressTrack');
  sections.forEach((_,i) => {
    const d = document.createElement('div');
    d.className = 'progress-dot'; d.dataset.idx = i;
    track.appendChild(d);
  });
  function setDot(idx) {
    document.querySelectorAll('.progress-dot').forEach(d =>
      d.classList.toggle('active', +d.dataset.idx === idx));
  }

  // ---- HELPERS ----
  const show = id => { const e = document.getElementById(id); if(e) e.classList.add('shown'); };
  const draw = id => { const e = document.getElementById(id); if(e) e.classList.add('drawn'); };
  const wait = (fn, ms) => setTimeout(fn, ms);

  // ---- ELLIPSE PERIMETER (Ramanujan) ----
  function ellipePerim(rx, ry) {
    const a = Math.max(rx,ry), b = Math.min(rx,ry);
    return Math.PI * (3*(a+b) - Math.sqrt((3*a+b)*(a+3*b)));
  }
  function initEllipse(id, rx, ry) {
    const el = document.getElementById(id);
    if (!el) return;
    const p = ellipePerim(rx, ry);
    el.style.strokeDasharray = p;
    el.style.strokeDashoffset = p;
  }

  initEllipse('circle1', 190, 88); // ≈ 903
  initEllipse('circle2', 96, 56);  // ≈ 486

  // ---- ANIMATION SEQUENCES ----
  const triggered = new Set();

  const sequences = {
    '0': () => setDot(0),

    '1': () => {
      setDot(1);
      show('s1-label');
      // NOT items stagger in then get crossed
      [1,2,3,4,5].forEach((i, idx) => {
        wait(() => show('n'+i), idx*140);
        wait(() => draw('s'+i), idx*140 + 120);
      });
      wait(() => show('n-note'), 900);
      // Rejected path arrow
      wait(() => draw('l-reject'), 1000);
      // Degree ellipse FULL CIRCLE
      wait(() => {
        const el = document.getElementById('circle1');
        el.style.transition = 'stroke-dashoffset 1.9s cubic-bezier(0.25,0,0.2,1)';
        el.style.strokeDashoffset = '0';
        wait(() => {
          show('t-n1'); show('t-n2'); show('t-n3');
          show('t-star'); show('t-star2'); show('t-star3');
        }, 900);
      }, 1100);
      // STEM branch
      wait(() => {
        draw('l-stem');
        wait(() => {
          show('t-stem'); show('t-s1'); show('t-s2'); show('t-s3');
          show('icon-clock');
        }, 900);
      }, 2100);
      // Creative branch
      wait(() => {
        draw('l-ns');
        wait(() => {
          show('t-ns'); show('t-ns1'); show('t-ns2'); show('t-ns3'); show('t-ns4'); show('t-ns5');
          show('icon-bulb');
          wait(() => draw('l-wobble'), 400);
        }, 900);
      }, 3000);
    },

    '2': () => {
      setDot(2);
      show('s2-label');
      show('t2-year');
      wait(() => draw('l2-wave'), 300);
      wait(() => {
        const el = document.getElementById('circle2');
        el.style.transition = 'stroke-dashoffset 1.5s cubic-bezier(0.25,0,0.2,1)';
        el.style.strokeDashoffset = '0';
        wait(() => show('t2-ai'), 750);
      }, 700);
      wait(() => {
        draw('l2-m'); draw('l2-p'); draw('l2-f');
        wait(() => {
          show('t2-m'); show('t2-m1'); show('t2-m2'); show('t2-m3');
          show('t2-p'); show('t2-p2'); show('t2-p3'); show('t2-p4');
          show('t2-f'); show('t2-f2'); show('t2-f3'); show('t2-f4');
        }, 900);
      }, 1400);
      wait(() => {
        draw('l2-loop');
        wait(() => show('icon-compound'), 500);
      }, 2400);
    },

    '3': () => {
      setDot(3);
      const fs = document.getElementById('formulaSection');
      fs.classList.add('shown');
      wait(() => show('f-ch'), 100);
      wait(() => { show('f-t1'); show('f-plus'); show('f-t2'); }, 400);
      wait(() => draw('f-eq'), 800);
      wait(() => show('f-res'), 1100);
      wait(() => draw('f-div'), 1500);
      wait(() => { show('box1'); show('f-b1a'); show('f-b1b'); show('f-b1c'); }, 1800);
      wait(() => { show('box2'); show('f-b2a'); show('f-b2b'); show('f-b2c'); }, 2200);
      wait(() => { show('box3'); show('f-b3a'); show('f-b3b'); show('f-b3c'); }, 2600);
      wait(() => { show('f-src'); show('f-src2'); }, 3000);
      wait(() => show('f-cta'), 3400);
    },

    '4': () => {
      setDot(4);
      wait(() => {
        document.getElementById('finalTitle').classList.add('shown');
        document.getElementById('finalCta').classList.add('shown');
      }, 200);
    }
  };

  // ---- OBSERVER ----
  const obs = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const sec = entry.target.dataset.section;
      if (triggered.has(sec)) return;
      triggered.add(sec);
      const fn = sequences[sec];
      if (fn) fn(entry.target);
    });
  }, { threshold: 0.25 });

  sections.forEach(s => obs.observe(s));

  // ---- INK DROP CURSOR ----
  document.addEventListener('mousemove', e => {
    if (Math.random() > 0.9) {
      const d = document.createElement('div');
      const sz = Math.random() * 4 + 3;
      d.className = 'ink-drop';
      d.style.cssText = `width:${sz}px;height:${sz}px;left:${e.clientX-sz/2}px;top:${e.clientY-sz/2}px;`;
      document.body.appendChild(d);
      setTimeout(() => d.remove(), 700);
    }
  });
</script>
</body>
